#!/usr/bin/env bash
set -uo pipefail

# ═══════════════════════════════════════════════════════════════════
# work-issue - Claude Code autonomous workflow orchestrator
# ═══════════════════════════════════════════════════════════════════
# Usage: work-issue <issue-number> [--effort high|xhigh|max] [--model <model>] [--resume <stage>]
#
# Orchestrates a full issue-to-PR workflow by launching sequential
# Claude Code sessions, each with a dedicated skill and fresh context.
#
# Stages run as a state machine, not a rigid sequence. Pre-execution
# stages (research/interview/plan) can loop freely. Post-execution
# stages (verify/review/integrate) can loop back to verify. A hard
# wall separates planning from execution.
#
# Skills request non-default transitions by writing a stage name to
# ./claude-work/<issue>/.next-stage
#
# Part of the issue-workflow plugin for Claude Code.
# https://github.com/22a435/claude-plugins
# ═══════════════════════════════════════════════════════════════════

# ── Self-location ─────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
PLUGIN_ROOT="$(dirname "$SCRIPT_DIR")"

# ── Valid stages (for --resume validation) ────────────────────────
readonly ALL_STAGES=(setup research interview plan execute debug verify review integrate)

# ── Transition rules ──────────────────────────────────────────────
# Each stage maps to its space-delimited list of allowed next stages.
declare -A ALLOWED_TRANSITIONS=(
  [setup]="research"
  [research]="interview research"
  [interview]="plan research interview"
  [plan]="execute research interview plan"
  [execute]="verify debug"
  [debug]="execute verify review"
  [verify]="review verify debug"
  [review]="integrate verify review debug"
  [integrate]="verify integrate done"
)

declare -A DEFAULT_NEXT=(
  [setup]="research"
  [research]="interview"
  [interview]="plan"
  [plan]="execute"
  [execute]="verify"
  [debug]="verify"
  [verify]="review"
  [review]="integrate"
  [integrate]="verify"
)

declare -A STAGE_DESC=(
  [setup]="Branch, work folder, Issue.md, and environment init"
  [research]="Deep investigation of the issue"
  [interview]="Resolve open questions with user"
  [plan]="Draft and approve implementation plan"
  [execute]="Implement the plan"
  [debug]="Root cause analysis and fix for escalated problems"
  [verify]="Full verification suite"
  [review]="Code quality review"
  [integrate]="Prepare branch for merge"
)

# ── Skill invocations ─────────────────────────────────────────────
# Fully qualified names avoid collisions with built-in commands.
# Override with ISSUE_WORKFLOW_SKILL_PREFIX="" to use short names.
_PREFIX="${ISSUE_WORKFLOW_SKILL_PREFIX:-issue-workflow:}"

declare -A STAGE_SKILL=(
  [research]="/${_PREFIX}research"
  [interview]="/${_PREFIX}interview"
  [plan]="/${_PREFIX}plan"
  [execute]="/${_PREFIX}execute"
  [debug]="/${_PREFIX}debug"
  [verify]="/${_PREFIX}verify"
  [review]="/${_PREFIX}review"
  [integrate]="/${_PREFIX}integrate"
)

declare -A STAGE_DOC=(
  [research]="Research.md"
  [interview]="Interview.md"
  [plan]="Plan.md"
  [execute]="Execute.md"
  [debug]="Debug.md"
  [verify]="Verify.md"
  [review]="Review.md"
  [integrate]="Integration.md"
)

# ── Model assignments (configurable via env vars) ─────────────────
# Override all stages: ISSUE_WORKFLOW_MODEL=sonnet
# Override one stage: ISSUE_WORKFLOW_MODEL_RESEARCH=fable[1m]
# Per-stage env var takes precedence over the global override.
declare -A STAGE_MODEL=(
  [setup]="${ISSUE_WORKFLOW_MODEL_SETUP:-${ISSUE_WORKFLOW_MODEL:-haiku}}"
  [research]="${ISSUE_WORKFLOW_MODEL_RESEARCH:-${ISSUE_WORKFLOW_MODEL:-opus[1m]}}"
  [interview]="${ISSUE_WORKFLOW_MODEL_INTERVIEW:-${ISSUE_WORKFLOW_MODEL:-opus[1m]}}"
  [plan]="${ISSUE_WORKFLOW_MODEL_PLAN:-${ISSUE_WORKFLOW_MODEL:-opus[1m]}}"
  [execute]="${ISSUE_WORKFLOW_MODEL_EXECUTE:-${ISSUE_WORKFLOW_MODEL:-opus[1m]}}"
  [debug]="${ISSUE_WORKFLOW_MODEL_DEBUG:-${ISSUE_WORKFLOW_MODEL:-opus[1m]}}"
  [verify]="${ISSUE_WORKFLOW_MODEL_VERIFY:-${ISSUE_WORKFLOW_MODEL:-opus[1m]}}"
  [review]="${ISSUE_WORKFLOW_MODEL_REVIEW:-${ISSUE_WORKFLOW_MODEL:-opus[1m]}}"
  [integrate]="${ISSUE_WORKFLOW_MODEL_INTEGRATE:-${ISSUE_WORKFLOW_MODEL:-opus[1m]}}"
)

# ── Effort assignments (configurable via env vars) ────────────────
declare -A STAGE_EFFORT=(
  [setup]="${ISSUE_WORKFLOW_EFFORT_SETUP:-low}"
  [research]="${ISSUE_WORKFLOW_EFFORT_RESEARCH:-xhigh}"
  [interview]="${ISSUE_WORKFLOW_EFFORT_INTERVIEW:-xhigh}"
  [plan]="${ISSUE_WORKFLOW_EFFORT_PLAN:-xhigh}"
  [execute]="${ISSUE_WORKFLOW_EFFORT_EXECUTE:-xhigh}"
  [debug]="${ISSUE_WORKFLOW_EFFORT_DEBUG:-xhigh}"
  [verify]="${ISSUE_WORKFLOW_EFFORT_VERIFY:-xhigh}"
  [review]="${ISSUE_WORKFLOW_EFFORT_REVIEW:-xhigh}"
  [integrate]="${ISSUE_WORKFLOW_EFFORT_INTEGRATE:-xhigh}"
)

# ── Defaults ──────────────────────────────────────────────────────
EFFORT="${CLAUDE_CODE_EFFORT_LEVEL:-xhigh}"
EFFORT_EXPLICIT=false
RESUME_FROM=""
ISSUE=""
CLI_TARGET=""   # --target <branch>   (explicit merge target override)
CLI_BUMP=""     # --bump major|minor|patch  (semver update-branch routing)
CLI_ONTO=""     # --onto <branch|PR#> (stack onto an existing feature branch)

# ── Usage / help ──────────────────────────────────────────────────
usage() {
  cat <<'EOF'
Usage: work-issue <issue-number> [OPTIONS]

Orchestrates a full issue-to-PR workflow using Claude Code skills.
Stages run as a state machine -- pre-execution stages can loop freely,
post-execution stages can loop back to verify.

Options:
  --effort <level>   Effort level: high, xhigh (default), or max
  --model <model>    Override model for all stages (e.g., sonnet, fable[1m])
  --resume <stage>   Resume from a specific stage (skips prior stages)
  --target <branch>  Merge target branch (default: main, or per-repo config).
                     Overrides --bump and the config target.
  --bump <level>     major|minor|patch -- route to the matching semver
                     update branch from .claude-workflows.json. Falls back
                     to a single "semver:<level>" issue label, then config.
  --onto <branch|PR> Stack this work onto an existing feature branch or open
                     PR: cut from it and target it (sequential/stacked PRs).
  --help             Show this help message

Stages:
  setup        Create branch, work folder, Issue.md; run repo setup
  research     Deep codebase + web + library investigation
  interview    Resolve open questions with user input
  plan         Draft and approve implementation plan; open draft PR
  ── hard wall ── (no going back once execution starts)
  execute      Implement the plan; signals debug on failure
  debug        Root cause analysis and fix (triggered by execute/verify/review)
  verify       Full verification suite; signals debug on failure
  review       Code quality review; signals debug for critical/important issues
  integrate    Rebase onto the target branch; skips to done if it hasn't moved

Stage transitions:
  Research, interview, and plan can loop back to earlier stages.
  Execute, verify, and review signal debug when they encounter failures.
  Debug returns to the stage that triggered it after fixing the issue.
  Review signals verify when it makes code changes.
  Integrate signals done (target clean) or verify (after rebase).
  Skills signal non-default transitions via .next-stage file.
  Before marking the PR ready, a local CI gate re-checks the code state;
  stale state re-runs local CI inline, red re-enters verify, and the PR
  stays draft if local CI cannot go green.

Branching:
  By default this cuts a branch from origin/main and opens the PR against
  main. Drop a .claude-workflows.json at the target repo root to change the
  target branch, define major/minor/patch update branches, set the feature-
  branch prefix, and list protected branches. With no config and no flags,
  behavior is identical to before. See the plugin README.

Configuration (env vars):
  ISSUE_WORKFLOW_MODEL              Override model for all stages
  ISSUE_WORKFLOW_MODEL_<STAGE>      Override model for one stage (e.g., _RESEARCH)
  ISSUE_WORKFLOW_EFFORT_<STAGE>     Override effort for one stage
  ISSUE_WORKFLOW_SKILL_PREFIX       Skill name prefix (e.g., "issue-workflow:")
  ISSUE_WORKFLOW_TARGET_BRANCH      Merge target override (like --target)
  ISSUE_WORKFLOW_BRANCH_PREFIX      Feature-branch prefix (default "claude")
  ISSUE_WORKFLOW_SKIP_CI_GATE       Set to skip the pre-ready local CI gate
  CLAUDE_PLUGINS_SKIP_UPDATE        Set to skip the startup marketplace refresh

Auto-update:
  On fresh runs (not --resume), the orchestrator refreshes the marketplace
  and force-installs the latest plugin version before starting. The update
  takes effect on the next stage (every stage spawns a fresh claude session).
  Set CLAUDE_PLUGINS_SKIP_UPDATE=1 to skip.

Examples:
  work-issue 42                     # Full workflow for issue #42
  work-issue 42 --effort max        # Use max effort level
  work-issue 42 --model sonnet      # Use sonnet for all stages
  work-issue 42 --resume plan       # Resume from planning stage
  work-issue 42 --resume verify     # Re-run verification
  work-issue 42 --target develop    # Cut from / merge into develop
  work-issue 42 --bump minor        # Route to the minor update branch
  work-issue 43 --onto 42           # Stack #43 onto issue #42's open PR
EOF
  exit "${1:-0}"
}

# ── Parse arguments ───────────────────────────────────────────────
[[ $# -lt 1 ]] && usage 1
[[ "$1" == "--help" ]] && usage 0

ISSUE="$1"
shift

while [[ $# -gt 0 ]]; do
  case "$1" in
    --effort) EFFORT="${2:?--effort requires a value (high, xhigh, or max)}"; EFFORT_EXPLICIT=true; shift 2 ;;
    --model)
      ISSUE_WORKFLOW_MODEL="${2:?--model requires a value}"
      export ISSUE_WORKFLOW_MODEL
      # Re-apply to all stages
      for _s in "${ALL_STAGES[@]}"; do
        STAGE_MODEL[$_s]="${ISSUE_WORKFLOW_MODEL}"
      done
      shift 2
      ;;
    --resume) RESUME_FROM="${2:?--resume requires a stage name}"; shift 2 ;;
    --target) CLI_TARGET="${2:?--target requires a branch name}"; shift 2 ;;
    --bump)   CLI_BUMP="${2:?--bump requires major, minor, or patch}"; shift 2 ;;
    --onto)   CLI_ONTO="${2:?--onto requires a branch name or PR number}"; shift 2 ;;
    --help)   usage 0 ;;
    *)        echo "Error: unknown option: $1"; usage 1 ;;
  esac
done

export CLAUDE_CODE_EFFORT_LEVEL="$EFFORT"

# Validate resume stage if provided
if [[ -n "$RESUME_FROM" ]]; then
  valid=false
  for s in "${ALL_STAGES[@]}"; do
    [[ "$s" == "$RESUME_FROM" ]] && valid=true
  done
  if [[ "$valid" != "true" ]]; then
    echo "Error: invalid stage '${RESUME_FROM}'"
    echo "Valid stages: ${ALL_STAGES[*]}"
    exit 1
  fi
fi

# Validate bump level if provided
if [[ -n "$CLI_BUMP" && "$CLI_BUMP" != "major" && "$CLI_BUMP" != "minor" && "$CLI_BUMP" != "patch" ]]; then
  echo "Error: invalid --bump '${CLI_BUMP}' (expected major, minor, or patch)"
  exit 1
fi

# ── Validate environment ──────────────────────────────────────────
for cmd in gh claude git jq; do
  command -v "$cmd" >/dev/null 2>&1 || {
    echo "Error: required command '${cmd}' not found"; exit 1
  }
done

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || {
  echo "Error: not inside a git repository"; exit 1
}
cd "$REPO_ROOT"

# NOTE: Permissions are handled by settings.json (defaultMode: bypassPermissions).
# If that doesn't work in practice, add --dangerously-skip-permissions to each
# claude invocation below.

# ── Plugin self-update ────────────────────────────────────────────
# Refresh the marketplace catalog, then force-install the latest plugin
# version. The update takes effect on the next stage's fresh claude
# invocation (every stage is a restart). Skipped on --resume to avoid
# skill/orchestrator changes mid-workflow.
if [[ -z "$RESUME_FROM" && -z "${CLAUDE_PLUGINS_SKIP_UPDATE:-}" ]]; then
  echo "Checking for plugin updates..."
  timeout --kill-after=5 20 claude plugin marketplace update 22a435-workflows </dev/null || true
  if ! timeout --kill-after=5 20 claude plugin update issue-workflow@22a435-workflows </dev/null; then
    echo "Warning: plugin update failed or timed out; continuing with installed version." >&2
  fi
fi

# ── Read issue from GitHub (body + full comment thread) ───────────
# Comments are fetched too: scope and context frequently live in replies,
# not the original body. The thread is rendered into Issue.md so every
# downstream stage sees it.
echo "Reading issue #${ISSUE} (with comment thread)..."
ISSUE_JSON="$(gh issue view "$ISSUE" --json title,body,labels,comments 2>/dev/null)" || {
  echo "Error: could not read issue #${ISSUE}. Check gh auth and issue number."
  exit 1
}
ISSUE_TITLE="$(echo "$ISSUE_JSON" | jq -r '.title')"
ISSUE_BODY="$(echo "$ISSUE_JSON" | jq -r '.body')"
ISSUE_LABELS="$(echo "$ISSUE_JSON" | jq -r '[.labels[].name] | join(", ")')"
# Render the comment thread as markdown (data only -- never executed).
ISSUE_THREAD="$(echo "$ISSUE_JSON" | jq -r '
  if (.comments | length) == 0 then
    "No comments."
  else
    [.comments[] | "### Comment by \(.author.login // "unknown") -- \(.createdAt)\n\n\(.body)"]
    | join("\n\n---\n\n")
  end
')"
GITHUB_REPO="$(gh repo view --json nameWithOwner -q .nameWithOwner)"

WORK_DIR="${REPO_ROOT}/claude-work/${ISSUE}"

# ── Resolve branching model (target/base branch, bump routing, stacking) ──
# Detect a single semver:<level> label so an issue can self-route to its
# update branch when neither --bump nor --target is given.
WF_LABEL_BUMP="$(echo "$ISSUE_JSON" | jq -r '
  [.labels[].name | select(test("^semver:(major|minor|patch)$")) | ltrimstr("semver:")]
  | if length == 1 then .[0] else empty end')"
WF_TARGET_OVERRIDE="${ISSUE_WORKFLOW_TARGET_BRANCH:-}"
WF_PREFIX_OVERRIDE="${ISSUE_WORKFLOW_BRANCH_PREFIX:-}"
# shellcheck source=_branch-lib.sh
source "${SCRIPT_DIR}/_branch-lib.sh"
resolve_branches || { echo "Error: could not resolve target branch."; exit 1; }
# On --resume, reuse the base the branch was set up with (recorded at setup).
if [[ -n "$RESUME_FROM" ]]; then
  load_branch_meta "$WORK_DIR" || true
fi

BRANCH="${WF_BRANCH_PREFIX}/${ISSUE}"

# ── Banner ────────────────────────────────────────────────────────
echo ""
echo "═══════════════════════════════════════════════════════════"
echo "  Issue #${ISSUE}: ${ISSUE_TITLE}"
echo "  Repo:   ${GITHUB_REPO}"
echo "  Branch: ${BRANCH}"
echo "  Target: ${WF_TARGET}"
[[ -n "$WF_BUMP" ]] && echo "  Bump:   ${WF_BUMP}"
[[ -n "$WF_STACK_FINAL_TARGET" ]] && echo "  Stack:  onto ${WF_TARGET} (final target ${WF_STACK_FINAL_TARGET}${WF_STACK_PARENT_PR:+, parent PR #${WF_STACK_PARENT_PR}})"
echo "  Effort: ${EFFORT}"
[[ -n "$RESUME_FROM" ]] && echo "  Resume: from ${RESUME_FROM}"
echo "═══════════════════════════════════════════════════════════"
echo ""

# ── Helpers ───────────────────────────────────────────────────────
stage_banner() {
  local stage="$1" desc="$2" model="$3" effort="$4"
  echo ""
  echo "───────────────────────────────────────────────────────────"
  echo "  Stage: ${stage} -- ${desc}"
  echo "  Model: ${model}  Effort: ${effort}"
  echo "───────────────────────────────────────────────────────────"
  echo ""
}

resolve_stage_effort() {
  local stage="$1"
  if [[ "$EFFORT_EXPLICIT" == "true" ]]; then
    echo "$EFFORT"
  else
    echo "${STAGE_EFFORT[$stage]:-$EFFORT}"
  fi
}

refresh_env() {
  # After a stage installs tools (via setup scripts, package managers, etc.),
  # PATH in this shell is stale. Spawn a fresh interactive login shell to pick
  # up changes from ~/.bashrc, ~/.profile, /etc/profile.d/*, etc.
  # NOTE: must be -lic (interactive), not just -lc. Ubuntu's .bashrc exits
  # early for non-interactive shells, skipping nvm/fnm/volta init.
  local new_path
  new_path="$(bash -lic 'echo "$PATH"' 2>/dev/null)" || return 0
  if [[ -n "$new_path" ]]; then
    export PATH="$new_path"
  fi
}

check_document() {
  local doc="$1"
  if [[ -f "${WORK_DIR}/${doc}" ]]; then
    echo "[ok] ${doc} exists."
    return 0
  else
    echo "[!!] ${doc} not found. Stage may not have completed successfully."
    read -rp "Continue to next stage anyway? [y/N] " yn
    case "$yn" in
      [Yy]*) return 0 ;;
      *)     echo "Aborting. Re-run with: work-issue ${ISSUE} --resume <stage>"
             exit 1 ;;
    esac
  fi
}

validate_transition() {
  local from="$1" to="$2"
  local allowed="${ALLOWED_TRANSITIONS[$from]:-}"
  for stage in $allowed; do
    [[ "$stage" == "$to" ]] && return 0
  done
  return 1
}

resolve_next_stage() {
  local current="$1"
  local signal_file="${WORK_DIR}/.next-stage"

  if [[ -f "$signal_file" ]]; then
    local next
    next="$(< "$signal_file")"
    rm -f "$signal_file"
    next="${next//[[:space:]]/}"  # trim whitespace

    if [[ -n "$next" ]] && validate_transition "$current" "$next"; then
      echo "[signal] Stage '${current}' requested transition to '${next}'" >&2
      echo "$next"
      return
    elif [[ -n "$next" ]]; then
      echo "[signal] WARNING: Stage '${current}' requested '${next}' but that transition is not allowed. Using default." >&2
    fi
  fi

  # Dynamic default for debug: return to the stage that triggered it
  if [[ "$current" == "debug" ]]; then
    local origin_file="${WORK_DIR}/.debug-origin"
    if [[ -f "$origin_file" ]]; then
      local origin
      origin="$(< "$origin_file")"
      origin="${origin//[[:space:]]/}"
      if [[ -n "$origin" ]] && validate_transition "debug" "$origin"; then
        echo "[debug] Returning to origin stage '${origin}'" >&2
        echo "$origin"
        return
      fi
    fi
  fi

  echo "${DEFAULT_NEXT[$current]}"
}

clean_signal_file() {
  rm -f "${WORK_DIR}/.next-stage"
}

# ── Local CI pre-ready gate ───────────────────────────────────────
# The verify skill records the repo's local CI command plus a content
# hash of the validated tree in <work-dir>/.local-ci-state (committed).
# Target repos only run GitHub Actions once a PR is marked ready, so
# before `gh pr ready` we confirm local CI was run against the FINAL
# code state -- catching e.g. a debug fix after review that was never
# re-verified. Set ISSUE_WORKFLOW_SKIP_CI_GATE=1 to bypass.
MAX_GATE_REENTRIES=2
gate_reentries=0
PR_STAY_DRAFT=false

compute_tree_hash() {
  # Content hash of the committed tree, excluding claude-work/ so that
  # doc-only commits (Verify.md, Review.md, the marker itself) do not
  # invalidate a green run. History-independent: rebases that preserve
  # content keep the hash; any real code change produces a new one.
  git ls-tree -r HEAD | awk -F'\t' '$2 !~ /^claude-work\//' | sha256sum | awk '{print $1}'
}

marker_field() {
  grep -m1 "^${1}=" "${WORK_DIR}/.local-ci-state" 2>/dev/null | cut -d= -f2-
}

local_ci_gate() {
  # Returns 0 -> safe to mark the PR ready; 1 -> re-enter at verify.
  [[ -n "${ISSUE_WORKFLOW_SKIP_CI_GATE:-}" ]] && return 0

  local marker="${WORK_DIR}/.local-ci-state"
  if [[ ! -f "$marker" ]]; then
    echo "[gate] No local CI marker (${marker}). Verify must establish local CI state."
    return 1
  fi

  local cmd status recorded current
  cmd="$(marker_field command)"
  status="$(marker_field status)"
  recorded="$(marker_field tree_hash)"

  if [[ "$cmd" == "none" || -z "$cmd" ]]; then
    echo "[gate] Repo has no local CI script (marker: command=none). Proceeding."
    return 0
  fi

  current="$(compute_tree_hash)"
  if [[ "$recorded" == "$current" ]]; then
    if [[ "$status" == "deferred" ]]; then
      echo "[gate] WARNING: local CI failures were deferred to follow-up issues."
      echo "[gate] GitHub Actions may show red on this PR. See ${WORK_DIR}/Verify.md."
    fi
    echo "[gate] Local CI state is fresh (tree ${current:0:12}). Proceeding."
    return 0
  fi

  # Stale: code changed since the last recorded local CI run. Cheap
  # path first -- re-run the recorded command inline before paying for
  # a full verify pipeline re-entry.
  echo "[gate] Code changed since last local CI run (recorded ${recorded:0:12}, now ${current:0:12})."
  echo "[gate] Re-running local CI inline: ${cmd}"
  local log="/tmp/work-issue-${ISSUE}-local-ci-gate.log"
  if bash -c "$cmd" >"$log" 2>&1; then
    echo "[gate] Local CI GREEN against final tree. Updating marker."
    cat > "$marker" << MARKER_EOF
command=${cmd}
tree_hash=${current}
status=green
timestamp=$(date -u +%Y-%m-%dT%H:%M:%SZ)
MARKER_EOF
    git add "$marker"
    git commit -m "claude-work(gate): local CI green at ${current:0:12} [#${ISSUE}]" >/dev/null
    git push >/dev/null 2>&1 || true
    rm -f "$log"
    return 0
  fi
  echo "[gate] Local CI FAILED. Last 40 lines:"
  tail -n 40 "$log"
  echo "[gate] Full log: ${log}"
  return 1
}

# ── Loop safety ───────────────────────────────────────────────────
MAX_STAGE_RUNS=25
stage_run_count=0
declare -A STAGE_RUN_COUNTS

# ── Determine starting stage ─────────────────────────────────────
current_stage="setup"
if [[ -n "$RESUME_FROM" ]]; then
  current_stage="$RESUME_FROM"
fi

# ── Ensure correct branch (needed for resume or wrong checkout) ──
if [[ "$current_stage" != "setup" ]]; then
  git fetch origin "$WF_TARGET" 2>/dev/null || true
  current_branch="$(git symbolic-ref --short HEAD 2>/dev/null || true)"
  if [[ "$current_branch" != "$BRANCH" ]]; then
    if git show-ref --verify --quiet "refs/heads/${BRANCH}"; then
      echo "Switching to branch ${BRANCH} (was on ${current_branch:-detached HEAD})."
      git checkout "$BRANCH"
    else
      echo "Error: branch ${BRANCH} does not exist. Cannot resume without it."
      echo "Run without --resume to start from setup."
      exit 1
    fi
  fi
  git pull origin "$BRANCH" 2>/dev/null || true
fi

# ══════════════════════════════════════════════════════════════════
#  MAIN STATE MACHINE
# ══════════════════════════════════════════════════════════════════
while true; do
  # ── Pre-ready gate: intercept 'done' before leaving the loop ────
  # done -> verify is an orchestrator-level re-entry (like --resume),
  # not a skill transition, so it is not in ALLOWED_TRANSITIONS.
  if [[ "$current_stage" == "done" ]]; then
    if local_ci_gate; then
      break
    fi
    gate_reentries=$((gate_reentries + 1))
    if [[ $gate_reentries -gt $MAX_GATE_REENTRIES ]]; then
      echo ""
      echo "WARNING: local CI gate failed ${MAX_GATE_REENTRIES} times. Leaving the PR as a DRAFT."
      PR_STAY_DRAFT=true
      break
    fi
    echo "[gate] Re-entering the workflow at 'verify' (gate attempt ${gate_reentries}/${MAX_GATE_REENTRIES})."
    current_stage="verify"
    # fall through to normal stage execution
  fi

  # Loop safety: global limit
  stage_run_count=$((stage_run_count + 1))
  if [[ $stage_run_count -gt $MAX_STAGE_RUNS ]]; then
    echo ""
    echo "ERROR: Exceeded maximum stage executions (${MAX_STAGE_RUNS}). Possible infinite loop."
    echo "Last stage: ${current_stage}"
    echo "Re-run with --resume <stage> to continue manually."
    exit 1
  fi

  # Loop safety: per-stage limit
  STAGE_RUN_COUNTS[$current_stage]=$(( ${STAGE_RUN_COUNTS[$current_stage]:-0} + 1 ))
  if [[ ${STAGE_RUN_COUNTS[$current_stage]} -gt 5 ]]; then
    echo ""
    echo "WARNING: Stage '${current_stage}' has run ${STAGE_RUN_COUNTS[$current_stage]} times."
    read -rp "Continue? [y/N] " yn
    case "$yn" in
      [Yy]*) ;;
      *)     echo "Aborting. Re-run with --resume to continue manually."
             exit 1 ;;
    esac
  fi

  # Refresh PATH from login shell to pick up tools installed by prior stages
  refresh_env

  # Resolve model and effort for this stage
  stage_model="${STAGE_MODEL[$current_stage]}"
  stage_effort="$(resolve_stage_effort "$current_stage")"

  # Trivial integration: if the target branch hasn't diverged, handle it in bash
  if [[ "$current_stage" == "integrate" ]]; then
    # Effective integration base. When stacked and the parent PR has merged,
    # GitHub retargets this PR onto the final target -- measure divergence
    # against that, not the (now-merged) parent branch.
    integ_target="$WF_TARGET"; integ_base="$WF_BASE_REF"
    if [[ -n "$WF_STACK_PARENT_PR" && -n "$WF_STACK_FINAL_TARGET" ]] \
       && [[ "$(gh pr view "$WF_STACK_PARENT_PR" --json state -q .state 2>/dev/null)" == "MERGED" ]]; then
      echo "  Parent PR #${WF_STACK_PARENT_PR} merged; measuring integration against final target ${WF_STACK_FINAL_TARGET}."
      integ_target="$WF_STACK_FINAL_TARGET"; integ_base="origin/${WF_STACK_FINAL_TARGET}"
    fi
    git fetch origin "$integ_target" 2>/dev/null || true
    diverged_commits=$(git log --oneline "HEAD..${integ_base}" 2>/dev/null | wc -l)
    if [[ $diverged_commits -eq 0 ]]; then
      stage_banner "$current_stage" "${STAGE_DESC[$current_stage]}" "bash (inline)" "n/a"

      # Write trivial Integration.md
      cat > "${WORK_DIR}/Integration.md" << INTEG_EOF
# Integration Report: Issue #${ISSUE}

## Summary
\`${integ_base}\` has not diverged. No integration needed. Branch is ready for merge.
INTEG_EOF

      # Commit, push, comment on PR
      git add "${WORK_DIR}/Integration.md"
      git commit -m "claude-work(integrate): no integration needed for issue #${ISSUE}"
      git push
      gh pr comment "$BRANCH" --body "**Integration:** \`${integ_base}\` has not diverged. No integration needed. Branch is ready for merge." 2>/dev/null || true

      # Signal done and advance
      echo "done" > "${WORK_DIR}/.next-stage"
      previous_stage="$current_stage"
      current_stage="$(resolve_next_stage "$current_stage")"
      continue
    fi
  fi

  stage_banner "$current_stage" "${STAGE_DESC[$current_stage]}" "$stage_model" "$stage_effort"

  case "$current_stage" in
    # ── SETUP (inline -- unique logic, not a skill) ────────────
    setup)
      # Create or switch to branch. Cut from the resolved base ref
      # (origin/<target>, or origin/<parent> when stacking with --onto).
      git fetch origin "$WF_TARGET" 2>/dev/null || true
      if git show-ref --verify --quiet "refs/heads/${BRANCH}"; then
        echo "Branch ${BRANCH} exists. Switching to it."
        git checkout "$BRANCH"
        git pull origin "$BRANCH" 2>/dev/null || true
      else
        echo "Creating branch ${BRANCH} from ${WF_BASE_REF}."
        git checkout -b "$BRANCH" "$WF_BASE_REF"
      fi

      # Create work directory
      mkdir -p "$WORK_DIR"

      # Record the resolved branching decision so --resume reuses this base.
      write_branch_meta "$WORK_DIR"

      # Write Issue.md (header uses variable expansion; body appended literally
      # via printf to prevent command injection from issue text)
      cat > "${WORK_DIR}/Issue.md" << ISSUE_EOF
# Issue #${ISSUE}: ${ISSUE_TITLE}

## Source
- **Repository:** ${GITHUB_REPO}
- **Issue:** [#${ISSUE}](https://github.com/${GITHUB_REPO}/issues/${ISSUE})
- **Branch:** \`${BRANCH}\`
- **Merge target:** \`${WF_TARGET}\`${WF_BUMP:+ (bump: ${WF_BUMP})}${WF_STACK_FINAL_TARGET:+ -- stacked; final target \`${WF_STACK_FINAL_TARGET}\`${WF_STACK_PARENT_PR:+, parent PR #${WF_STACK_PARENT_PR}}}
- **Labels:** ${ISSUE_LABELS:-none}

## Issue Text

ISSUE_EOF
      printf '%s\n' "$ISSUE_BODY" >> "${WORK_DIR}/Issue.md"

      # Append the full comment thread (body appended literally via printf to
      # prevent command injection from issue/comment text)
      {
        printf '\n## Discussion Thread\n\n'
        printf '%s\n' "$ISSUE_THREAD"
      } >> "${WORK_DIR}/Issue.md"

      # Commit and push
      git add "${WORK_DIR}/Issue.md" "${WORK_DIR}/.branch-meta.json"
      git commit -m "claude-work: begin issue #${ISSUE} -- ${ISSUE_TITLE}"
      git push -u origin "$BRANCH"

      # Run environment setup via Claude
      echo ""
      echo "Launching Claude to run repo-specific setup..."
      echo ""
      claude --model "$stage_model" --effort "$stage_effort" "Check this repo's CLAUDE.md, README, and look for setup scripts (scripts/setup.sh, Makefile setup targets, package.json scripts, etc.). Run whatever is needed to initialize the development environment. Report what you did when complete."

      current_stage="research"
      ;;

    # ── ALL SKILL-BASED STAGES ─────────────────────────────────
    research|interview|plan|execute|debug|verify|review|integrate)
      clean_signal_file
      claude --model "$stage_model" --effort "$stage_effort" "${STAGE_SKILL[$current_stage]} ${ISSUE}"

      doc="${STAGE_DOC[$current_stage]:-}"
      if [[ -n "$doc" ]]; then
        check_document "$doc"
      fi

      previous_stage="$current_stage"
      current_stage="$(resolve_next_stage "$current_stage")"

      # Save origin when transitioning TO debug
      if [[ "$current_stage" == "debug" ]]; then
        echo "$previous_stage" > "${WORK_DIR}/.debug-origin"
        echo "[debug] Saved origin stage '${previous_stage}'"
      fi
      ;;

    *)
      echo "ERROR: unknown stage '${current_stage}'"
      exit 1
      ;;
  esac
done

# ══════════════════════════════════════════════════════════════════
#  COMPLETE
# ══════════════════════════════════════════════════════════════════

# Mark the PR as ready for review (no longer draft) -- unless the
# local CI gate could not confirm green against the final code state.
if [[ "$PR_STAY_DRAFT" == "true" ]]; then
  echo "NOT marking the PR ready: local CI is not confirmed green against the final code state."
  echo "Fix locally (see /tmp/work-issue-${ISSUE}-local-ci-gate.log and ${WORK_DIR}/Verify.md),"
  echo "then re-run: work-issue ${ISSUE} --resume verify"
else
  echo "Marking PR as ready for review..."
  gh pr ready "$BRANCH" 2>/dev/null && echo "PR marked as ready." || echo "WARNING: Could not mark PR as ready (may already be non-draft or PR not found)."
fi

echo ""
echo "═══════════════════════════════════════════════════════════"
echo "  Workflow complete for issue #${ISSUE}"
echo "  Branch: ${BRANCH}"
echo "  Work:   ${WORK_DIR}/"
echo ""
if [[ "$PR_STAY_DRAFT" == "true" ]]; then
  echo "  The PR remains a DRAFT: local CI is not confirmed green."
else
  echo "  The PR is ready for final human review and merge."
fi
echo "  To re-run integration if main has moved:"
echo "    work-issue ${ISSUE} --resume integrate"
echo "═══════════════════════════════════════════════════════════"
