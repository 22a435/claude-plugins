#!/usr/bin/env bash
set -uo pipefail

# ═══════════════════════════════════════════════════════════════════
# triage - Claude Code issue triage / consolidation orchestrator
# ═══════════════════════════════════════════════════════════════════
# Usage: triage [--effort high|xhigh|max] [--model <model>] [--resume <stage>] [--session <N>]
#
# Reads the open GitHub issues and in-code TODOs, closes the ones that
# are already fixed or duplicated, and consolidates the rest into a
# small, loosely-coupled set of well-scoped issues -- each a single-PR
# bite for the issue workflow. Nothing is mutated on GitHub until the
# full plan is approved in the interview stage.
#
# Stages run as a state machine. Pre-consolidate stages can loop freely.
# The interview stage is a whole-plan approval gate: no issue is closed
# or created before the user approves the plan.
#
# Skills request non-default transitions by writing a stage name to
# ./claude-triages/<session>/.next-stage
#
# Part of the triage plugin for Claude Code.
# https://github.com/22a435/claude-plugins
# ═══════════════════════════════════════════════════════════════════

# ── Self-location ─────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
PLUGIN_ROOT="$(dirname "$SCRIPT_DIR")"

# ── Valid stages (for --resume validation) ────────────────────────
readonly ALL_STAGES=(setup inventory reconcile cluster interview consolidate verify integrate)

# ── Transition rules ──────────────────────────────────────────────
# Each stage maps to its space-delimited list of allowed next stages.
declare -A ALLOWED_TRANSITIONS=(
  [setup]="inventory"
  [inventory]="reconcile inventory"
  [reconcile]="cluster inventory reconcile"
  [cluster]="interview reconcile cluster"
  [interview]="consolidate cluster reconcile interview"
  [consolidate]="verify consolidate"
  [verify]="integrate consolidate verify"
  [integrate]="verify integrate done"
)

declare -A DEFAULT_NEXT=(
  [setup]="inventory"
  [inventory]="reconcile"
  [reconcile]="cluster"
  [cluster]="interview"
  [interview]="consolidate"
  [consolidate]="verify"
  [verify]="integrate"
  [integrate]="done"
)

declare -A STAGE_DESC=(
  [setup]="Branch, session folder, Session.md, draft PR, and environment init"
  [inventory]="Read every open issue (full threads) and in-code TODOs"
  [reconcile]="Classify each item: already-fixed / duplicate / still-live"
  [cluster]="Build the dependency graph and consolidate into bundles"
  [interview]="Present the full triage plan for approval (no mutations yet)"
  [consolidate]="Apply approved closes/merges/new issues on GitHub"
  [verify]="Confirm GitHub state matches the approved plan"
  [integrate]="Prepare report branch for merge"
)

# ── Skill invocations ─────────────────────────────────────────────
# Fully qualified names avoid collisions with built-in commands.
# Override with TRIAGE_SKILL_PREFIX="" to use short names.
_PREFIX="${TRIAGE_SKILL_PREFIX:-triage:}"

declare -A STAGE_SKILL=(
  [inventory]="/${_PREFIX}inventory"
  [reconcile]="/${_PREFIX}reconcile"
  [cluster]="/${_PREFIX}cluster"
  [interview]="/${_PREFIX}interview"
  [consolidate]="/${_PREFIX}consolidate"
  [verify]="/${_PREFIX}verify"
  [integrate]="/${_PREFIX}integrate"
)

declare -A STAGE_DOC=(
  [inventory]="Inventory.md"
  [reconcile]="Reconcile.md"
  [cluster]="Cluster.md"
  [interview]="Interview.md"
  [consolidate]="Triage.md"
  [verify]="Verify.md"
  [integrate]="Integration.md"
)

# ── Model assignments (configurable via env vars) ─────────────────
# Override all stages: TRIAGE_MODEL=sonnet
# Override one stage: TRIAGE_MODEL_CLUSTER=fable[1m]
# Per-stage env var takes precedence over the global override.
declare -A STAGE_MODEL=(
  [setup]="${TRIAGE_MODEL_SETUP:-${TRIAGE_MODEL:-haiku}}"
  [inventory]="${TRIAGE_MODEL_INVENTORY:-${TRIAGE_MODEL:-opus[1m]}}"
  [reconcile]="${TRIAGE_MODEL_RECONCILE:-${TRIAGE_MODEL:-opus[1m]}}"
  [cluster]="${TRIAGE_MODEL_CLUSTER:-${TRIAGE_MODEL:-opus[1m]}}"
  [interview]="${TRIAGE_MODEL_INTERVIEW:-${TRIAGE_MODEL:-opus[1m]}}"
  [consolidate]="${TRIAGE_MODEL_CONSOLIDATE:-${TRIAGE_MODEL:-opus[1m]}}"
  [verify]="${TRIAGE_MODEL_VERIFY:-${TRIAGE_MODEL:-opus[1m]}}"
  [integrate]="${TRIAGE_MODEL_INTEGRATE:-${TRIAGE_MODEL:-opus[1m]}}"
)

# ── Effort assignments (configurable via env vars) ────────────────
declare -A STAGE_EFFORT=(
  [setup]="${TRIAGE_EFFORT_SETUP:-low}"
  [inventory]="${TRIAGE_EFFORT_INVENTORY:-xhigh}"
  [reconcile]="${TRIAGE_EFFORT_RECONCILE:-max}"
  [cluster]="${TRIAGE_EFFORT_CLUSTER:-max}"
  [interview]="${TRIAGE_EFFORT_INTERVIEW:-xhigh}"
  [consolidate]="${TRIAGE_EFFORT_CONSOLIDATE:-xhigh}"
  [verify]="${TRIAGE_EFFORT_VERIFY:-xhigh}"
  [integrate]="${TRIAGE_EFFORT_INTEGRATE:-xhigh}"
)

# ── Defaults ──────────────────────────────────────────────────────
EFFORT="${CLAUDE_CODE_EFFORT_LEVEL:-xhigh}"
EFFORT_EXPLICIT=false
RESUME_FROM=""
SESSION_EXPLICIT=""

# ── Usage / help ──────────────────────────────────────────────────
usage() {
  cat <<'EOF'
Usage: triage [OPTIONS]

Consolidates open GitHub issues (and in-code TODOs) into a small set of
well-scoped, dependency-aware issues using Claude Code skills. Stages run
as a state machine; the interview stage gates all GitHub mutations behind
explicit user approval.

Options:
  --effort <level>   Effort level: high, xhigh (default), or max
  --model <model>    Override model for all stages (e.g., sonnet, fable[1m])
  --resume <stage>   Resume from a specific stage (requires --session)
  --session <N>      Use a specific session number (auto-increments if omitted)
  --help             Show this help message

Stages:
  setup          Create branch, session folder, Session.md, draft PR; run repo setup
  inventory      Read every open issue (full comment threads) and in-code TODOs
  reconcile      Classify each item: already-fixed / duplicate / still-live
  cluster        Build the dependency graph; consolidate into well-scoped bundles
  interview      Present the full triage plan for approval (no GitHub mutations yet)
  consolidate    Apply the approved closes/merges/new issues on GitHub
  verify         Confirm GitHub state matches the approved plan; salvage failed ops
  integrate      Rebase report branch onto main if needed; mark PR ready

Stage transitions:
  Pre-consolidate stages (inventory/reconcile/cluster) can loop back for more depth.
  Interview can loop back to cluster/reconcile if the user wants re-planning.
  Interview advances to consolidate only after the full plan is approved.
  Verify loops to consolidate if it finds gaps; advances to integrate if all match.
  Integrate handles rebase onto main; advances to done.
  Skills signal non-default transitions via .next-stage file.

Configuration (env vars):
  TRIAGE_MODEL                Override model for all stages
  TRIAGE_MODEL_<STAGE>        Override model for one stage (e.g., _CLUSTER)
  TRIAGE_EFFORT_<STAGE>       Override effort for one stage
  TRIAGE_SKILL_PREFIX         Skill name prefix (e.g., "triage:")
  CLAUDE_PLUGINS_SKIP_UPDATE  Set to skip the startup marketplace refresh

Auto-update:
  On fresh runs (not --resume), the orchestrator refreshes the marketplace
  and force-installs the latest plugin version before starting. The update
  takes effect on the next stage (every stage spawns a fresh claude session).
  Set CLAUDE_PLUGINS_SKIP_UPDATE=1 to skip.

Examples:
  triage                                   # New triage session
  triage --effort max                      # Use max effort level
  triage --model fable[1m]                  # Use fable for all stages
  triage --resume cluster --session 3      # Resume session 3 from clustering
  triage --resume interview --session 1    # Re-run the approval gate for session 1
EOF
  exit "${1:-0}"
}

# ── Parse arguments ───────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
  case "$1" in
    --effort) EFFORT="${2:?--effort requires a value (high, xhigh, or max)}"; EFFORT_EXPLICIT=true; shift 2 ;;
    --model)
      TRIAGE_MODEL="${2:?--model requires a value}"
      export TRIAGE_MODEL
      # Re-apply to all stages
      for _s in "${ALL_STAGES[@]}"; do
        STAGE_MODEL[$_s]="${TRIAGE_MODEL}"
      done
      shift 2
      ;;
    --resume) RESUME_FROM="${2:?--resume requires a stage name}"; shift 2 ;;
    --session) SESSION_EXPLICIT="${2:?--session requires a number}"; shift 2 ;;
    --help)   usage 0 ;;
    *)        echo "Error: unknown option: $1"; usage 1 ;;
  esac
done

export CLAUDE_CODE_EFFORT_LEVEL="$EFFORT"

# Validate resume stage if provided
if [[ -n "$RESUME_FROM" ]]; then
  valid=false
  for s in "${ALL_STAGES[@]}"; do
    [[ "$s" == "$RESUME_FROM" ]] && valid=true
  done
  if [[ "$valid" != "true" ]]; then
    echo "Error: invalid stage '${RESUME_FROM}'"
    echo "Valid stages: ${ALL_STAGES[*]}"
    exit 1
  fi
  if [[ -z "$SESSION_EXPLICIT" && "$RESUME_FROM" != "setup" ]]; then
    echo "Error: --resume requires --session <N> (which session to resume)"
    exit 1
  fi
fi

# ── Validate environment ──────────────────────────────────────────
for cmd in gh claude git jq; do
  command -v "$cmd" >/dev/null 2>&1 || {
    echo "Error: required command '${cmd}' not found"; exit 1
  }
done

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || {
  echo "Error: not inside a git repository"; exit 1
}
cd "$REPO_ROOT"

# ── Plugin self-update ────────────────────────────────────────────
# Refresh the marketplace catalog, then force-install the latest plugin
# version. The update takes effect on the next stage's fresh claude
# invocation (every stage is a restart). Skipped on --resume to avoid
# skill/orchestrator changes mid-workflow.
if [[ -z "$RESUME_FROM" && -z "${CLAUDE_PLUGINS_SKIP_UPDATE:-}" ]]; then
  echo "Checking for plugin updates..."
  timeout --kill-after=5 20 claude plugin marketplace update 22a435-workflows </dev/null || true
  if ! timeout --kill-after=5 20 claude plugin update triage@22a435-workflows </dev/null; then
    echo "Warning: plugin update failed or timed out; continuing with installed version." >&2
  fi
fi

# ── Session numbering ────────────────────────────────────────────
TRIAGE_BASE="${REPO_ROOT}/claude-triages"
mkdir -p "$TRIAGE_BASE"

if [[ -n "$SESSION_EXPLICIT" ]]; then
  SESSION="$SESSION_EXPLICIT"
else
  LAST_SESSION=$(ls -1d "${TRIAGE_BASE}"/[0-9]* 2>/dev/null | xargs -I{} basename {} | sort -n | tail -1)
  SESSION=$(( ${LAST_SESSION:-0} + 1 ))
fi

WORK_DIR="${TRIAGE_BASE}/${SESSION}"
BRANCH="claude/triage/${SESSION}"
GITHUB_REPO="$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null || echo "unknown")"

# ── Banner ────────────────────────────────────────────────────────
echo ""
echo "═══════════════════════════════════════════════════════════"
echo "  Triage Session #${SESSION}"
echo "  Repo:   ${GITHUB_REPO}"
echo "  Branch: ${BRANCH}"
echo "  Effort: ${EFFORT}"
[[ -n "$RESUME_FROM" ]] && echo "  Resume: from ${RESUME_FROM}"
echo "═══════════════════════════════════════════════════════════"
echo ""

# ── Helpers ───────────────────────────────────────────────────────
stage_banner() {
  local stage="$1" desc="$2" model="$3" effort="$4"
  echo ""
  echo "───────────────────────────────────────────────────────────"
  echo "  Stage: ${stage} -- ${desc}"
  echo "  Model: ${model}  Effort: ${effort}"
  echo "───────────────────────────────────────────────────────────"
  echo ""
}

resolve_stage_effort() {
  local stage="$1"
  if [[ "$EFFORT_EXPLICIT" == "true" ]]; then
    echo "$EFFORT"
  else
    echo "${STAGE_EFFORT[$stage]:-$EFFORT}"
  fi
}

refresh_env() {
  # After a stage installs tools (via setup scripts, package managers, etc.),
  # PATH in this shell is stale. Spawn a fresh interactive login shell to pick
  # up changes from ~/.bashrc, ~/.profile, /etc/profile.d/*, etc.
  local new_path
  new_path="$(bash -lic 'echo "$PATH"' 2>/dev/null)" || return 0
  if [[ -n "$new_path" ]]; then
    export PATH="$new_path"
  fi
}

check_document() {
  local doc="$1"
  if [[ -f "${WORK_DIR}/${doc}" ]]; then
    echo "[ok] ${doc} exists."
    return 0
  else
    echo "[!!] ${doc} not found. Stage may not have completed successfully."
    read -rp "Continue to next stage anyway? [y/N] " yn
    case "$yn" in
      [Yy]*) return 0 ;;
      *)     echo "Aborting. Re-run with: triage --resume <stage> --session ${SESSION}"
             exit 1 ;;
    esac
  fi
}

validate_transition() {
  local from="$1" to="$2"
  local allowed="${ALLOWED_TRANSITIONS[$from]:-}"
  for stage in $allowed; do
    [[ "$stage" == "$to" ]] && return 0
  done
  return 1
}

resolve_next_stage() {
  local current="$1"
  local signal_file="${WORK_DIR}/.next-stage"

  if [[ -f "$signal_file" ]]; then
    local next
    next="$(< "$signal_file")"
    rm -f "$signal_file"
    next="${next//[[:space:]]/}"  # trim whitespace

    if [[ -n "$next" ]] && validate_transition "$current" "$next"; then
      echo "[signal] Stage '${current}' requested transition to '${next}'" >&2
      echo "$next"
      return
    elif [[ -n "$next" ]]; then
      echo "[signal] WARNING: Stage '${current}' requested '${next}' but that transition is not allowed. Using default." >&2
    fi
  fi

  echo "${DEFAULT_NEXT[$current]}"
}

clean_signal_file() {
  rm -f "${WORK_DIR}/.next-stage"
}

# ── Loop safety ───────────────────────────────────────────────────
MAX_STAGE_RUNS=25
stage_run_count=0
declare -A STAGE_RUN_COUNTS

# ── Determine starting stage ─────────────────────────────────────
current_stage="setup"
if [[ -n "$RESUME_FROM" ]]; then
  current_stage="$RESUME_FROM"
fi

# ── Ensure correct branch (needed for resume or wrong checkout) ──
if [[ "$current_stage" != "setup" ]]; then
  git fetch origin main 2>/dev/null || true
  current_branch="$(git symbolic-ref --short HEAD 2>/dev/null || true)"
  if [[ "$current_branch" != "$BRANCH" ]]; then
    if git show-ref --verify --quiet "refs/heads/${BRANCH}"; then
      echo "Switching to branch ${BRANCH} (was on ${current_branch:-detached HEAD})."
      git checkout "$BRANCH"
    else
      echo "Error: branch ${BRANCH} does not exist. Cannot resume without it."
      echo "Run without --resume to start from setup."
      exit 1
    fi
  fi
  git pull origin "$BRANCH" 2>/dev/null || true
fi

# ══════════════════════════════════════════════════════════════════
#  MAIN STATE MACHINE
# ══════════════════════════════════════════════════════════════════
while [[ "$current_stage" != "done" ]]; do
  # Loop safety: global limit
  stage_run_count=$((stage_run_count + 1))
  if [[ $stage_run_count -gt $MAX_STAGE_RUNS ]]; then
    echo ""
    echo "ERROR: Exceeded maximum stage executions (${MAX_STAGE_RUNS}). Possible infinite loop."
    echo "Last stage: ${current_stage}"
    echo "Re-run with --resume <stage> --session ${SESSION} to continue manually."
    exit 1
  fi

  # Loop safety: per-stage limit
  STAGE_RUN_COUNTS[$current_stage]=$(( ${STAGE_RUN_COUNTS[$current_stage]:-0} + 1 ))
  if [[ ${STAGE_RUN_COUNTS[$current_stage]} -gt 5 ]]; then
    echo ""
    echo "WARNING: Stage '${current_stage}' has run ${STAGE_RUN_COUNTS[$current_stage]} times."
    read -rp "Continue? [y/N] " yn
    case "$yn" in
      [Yy]*) ;;
      *)     echo "Aborting. Re-run with --resume to continue manually."
             exit 1 ;;
    esac
  fi

  # Refresh PATH from login shell to pick up tools installed by prior stages
  refresh_env

  # Resolve model and effort for this stage
  stage_model="${STAGE_MODEL[$current_stage]}"
  stage_effort="$(resolve_stage_effort "$current_stage")"

  stage_banner "$current_stage" "${STAGE_DESC[$current_stage]}" "$stage_model" "$stage_effort"

  case "$current_stage" in
    # ── SETUP (inline -- unique logic, not a skill) ────────────
    setup)
      # Create or switch to branch
      git fetch origin main 2>/dev/null || true
      if git show-ref --verify --quiet "refs/heads/${BRANCH}"; then
        echo "Branch ${BRANCH} exists. Switching to it."
        git checkout "$BRANCH"
        git pull origin "$BRANCH" 2>/dev/null || true
      else
        echo "Creating branch ${BRANCH} from origin/main."
        git checkout -b "$BRANCH" origin/main
      fi

      # Create work directory
      mkdir -p "${WORK_DIR}"

      # Write Session.md
      cat > "${WORK_DIR}/Session.md" << SESSION_EOF
# Triage Session #${SESSION}

## Source
- **Repository:** ${GITHUB_REPO}
- **Branch:** \`${BRANCH}\`
- **Started:** $(date -u +"%Y-%m-%dT%H:%M:%SZ")
SESSION_EOF

      # Commit and push
      git add "${WORK_DIR}/Session.md"
      git commit -m "claude-triage: begin triage session #${SESSION}"
      git push -u origin "$BRANCH"

      # Open a draft PR to carry the triage report (subsequent stages comment on it)
      if ! gh pr view "$BRANCH" >/dev/null 2>&1; then
        gh pr create --draft \
          --title "Triage session #${SESSION}" \
          --body "Automated issue triage / consolidation. Report artifacts live under \`claude-triages/${SESSION}/\`. GitHub issue mutations are applied only after the plan is approved in the interview stage." \
          --base main --head "$BRANCH" 2>/dev/null \
          && echo "Draft PR created." \
          || echo "WARNING: could not create draft PR (continuing; stages will retry comments)."
      fi

      # Run environment setup via Claude (so reconcile can investigate the code)
      echo ""
      echo "Launching Claude to run repo-specific setup..."
      echo ""
      claude --model "$stage_model" --effort "$stage_effort" "This is a fresh development environment for an issue-triage session that will need to read and search this codebase. Check this repo's CLAUDE.md, README, and look for setup scripts (scripts/setup.sh, Makefile setup targets, package.json scripts, etc.). Run whatever is needed to initialize the development environment so the code can be searched and built. Report what you did when complete."

      current_stage="inventory"
      ;;

    # ── TRIVIAL INTEGRATION (inline -- skip Claude when main hasn't moved)
    integrate)
      git fetch origin main 2>/dev/null || true
      diverged_commits=$(git log --oneline HEAD..origin/main 2>/dev/null | wc -l)
      if [[ $diverged_commits -eq 0 ]]; then
        echo "  Main has not diverged. Handling integration inline (no Claude session needed)."

        cat > "${WORK_DIR}/Integration.md" << INTEG_EOF
# Integration Report: Triage Session #${SESSION}

## Summary
Main has not diverged. No integration needed. Branch is ready for merge.
INTEG_EOF

        git add "${WORK_DIR}/Integration.md"
        git commit -m "claude-triage(integrate): no integration needed [session #${SESSION}]"
        git push
        gh pr comment "$BRANCH" --body "**Integration:** Main has not diverged. No integration needed. Branch is ready for merge." 2>/dev/null || true

        echo "done" > "${WORK_DIR}/.next-stage"
        previous_stage="$current_stage"
        current_stage="$(resolve_next_stage "$current_stage")"
      else
        echo "  Main has diverged (${diverged_commits} new commits). Launching Claude for integration."

        clean_signal_file
        claude --model "$stage_model" --effort "$stage_effort" "${STAGE_SKILL[$current_stage]} ${SESSION}"

        doc="${STAGE_DOC[$current_stage]:-}"
        if [[ -n "$doc" ]]; then
          check_document "$doc"
        fi

        previous_stage="$current_stage"
        current_stage="$(resolve_next_stage "$current_stage")"
      fi
      ;;

    # ── ALL SKILL-BASED STAGES ─────────────────────────────────
    inventory|reconcile|cluster|interview|consolidate|verify)
      clean_signal_file
      claude --model "$stage_model" --effort "$stage_effort" "${STAGE_SKILL[$current_stage]} ${SESSION}"

      doc="${STAGE_DOC[$current_stage]:-}"
      if [[ -n "$doc" ]]; then
        check_document "$doc"
      fi

      previous_stage="$current_stage"
      current_stage="$(resolve_next_stage "$current_stage")"
      ;;

    *)
      echo "ERROR: unknown stage '${current_stage}'"
      exit 1
      ;;
  esac
done

# ══════════════════════════════════════════════════════════════════
#  COMPLETE
# ══════════════════════════════════════════════════════════════════

# Mark the PR as ready for review (no longer draft)
echo "Marking PR as ready for review..."
gh pr ready "$BRANCH" 2>/dev/null && echo "PR marked as ready." || echo "WARNING: Could not mark PR as ready (may already be non-draft or PR not found)."

echo ""
echo "═══════════════════════════════════════════════════════════"
echo "  Triage session #${SESSION} complete"
echo "  Branch: ${BRANCH}"
echo "  Work:   ${WORK_DIR}/"
echo ""
echo "  The backlog has been consolidated. The PR carries the report."
echo "  Each resulting issue is a single-PR bite for: work-issue <n>"
echo "  To re-run a stage:"
echo "    triage --resume <stage> --session ${SESSION}"
echo "═══════════════════════════════════════════════════════════"
